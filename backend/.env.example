# ===========================================
# BACKEND ENVIRONMENT VARIABLES
# Copy file này thành .env và điền thông tin thực
# ===========================================

NODE_ENV=production
PORT=5000

# MongoDB Atlas - Lấy từ: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/idaz?retryWrites=true&w=majority

# JWT Secret - Tạo chuỗi ngẫu nhiên dài 64+ ký tự
# Gợi ý tạo: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING

JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_RANDOM_64_CHAR_STRING
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (domain thực)
FRONTEND_URL=https://idaz.com.vn

# Email SMTP (dùng để gửi mật khẩu & thông báo)
# Gmail: Cần bật "App Password" tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=IDAZ Agency <your-email@gmail.com>

# Google OAuth (Tùy chọn)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
